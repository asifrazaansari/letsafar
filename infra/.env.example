# ── Auth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                   # optional — only needed for Google OAuth
GOOGLE_CLIENT_SECRET=               # optional — only needed for Google OAuth
NEXTAUTH_SECRET=                    # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ── Backend ───────────────────────────────────────────────────────────────────
JWT_SECRET=                         # openssl rand -base64 32
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Database ──────────────────────────────────────────────────────────────────
DB_ENGINE=mongodb                   # or: postgresql
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rihla
DATABASE_URL=postgresql://user:pass@localhost:5432/rihla   # optional

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_URL=                  # optional for edge/serverless

# ── AI Models ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
XAI_API_KEY=                        # Grok
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# ── Maps ──────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
CLOUDINARY_URL=

# ── Production (Vercel + Railway) ─────────────────────────────────────────────
# NEXTAUTH_URL=https://rihla.vercel.app
# BACKEND_URL=https://rihla-api.up.railway.app
# NEXT_PUBLIC_API_URL=https://rihla-api.up.railway.app
# ALLOWED_ORIGINS=["https://rihla.vercel.app"]

